generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("GARCOM")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mesa {
  id        String   @id @default(cuid())
  numero    Int      @unique
  status    String   @default("LIVRE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
